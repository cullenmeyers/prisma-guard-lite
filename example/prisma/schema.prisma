generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  slug      String   @unique
  deletedAt DateTime?
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  metadata    Unsupported("jsonb")?
  externalId  String   @default(dbgenerated("gen_random_uuid()"))
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  message   String
  createdAt DateTime @default(now())
}
